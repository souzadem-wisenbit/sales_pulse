{
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/src/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/css/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000"}]
    },
    {
      "source": "/js/(.*)",
      "headers": [{"key": "Cache-Control", "value": "public, max-age=31536000"}]
    }
  ]
}
